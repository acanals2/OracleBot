# ============================================================================
# Oracle Bot — environment variables
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# ============================================================================

# ─── Database (Neon Postgres) ───────────────────────────────────────────────
# Get from: https://console.neon.tech → Project → Connection Details → Pooled
# Use the *pooled* connection string for the app, not direct.
DATABASE_URL="postgresql://USER:PASS@HOST.neon.tech/oraclebot?sslmode=require"

# ─── Authentication (Better Auth, self-hosted on Neon) ─────────────────────
# A long random string — used to sign session tokens.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Public URL Better Auth uses for callbacks. Defaults to NEXT_PUBLIC_APP_URL
# if unset; set explicitly in production.
BETTER_AUTH_URL="http://localhost:3000"

# OAuth providers — uncomment in lib/auth-config.ts when adding these.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# ─── Billing (Stripe) ───────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook signing secret — Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs — create products + prices in Stripe dashboard, paste IDs here.
# These map to the public catalog in lib/billing.ts.
STRIPE_PRICE_SCOUT_RUN="price_..."          # $29 single run credit
STRIPE_PRICE_BUILDER_RUN="price_..."        # $149 single run credit
STRIPE_PRICE_STUDIO_MONTHLY="price_..."     # $299 / mo subscription
STRIPE_PRICE_STACK_MONTHLY="price_..."      # $999 / mo subscription
STRIPE_PRICE_OVERAGE_PERSONA_MIN="price_..." # metered $0.04 per persona-minute

# ─── Queue + Workers (Railway Redis) ────────────────────────────────────────
# Get from: Railway dashboard → Redis service → Connect → Internal URL
# Use rediss:// (TLS) when connecting from outside Railway, redis:// internal.
REDIS_URL="redis://default:PASS@HOST.railway.internal:6379"

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Oracle Bot <hello@oraclebot.net>"

# ─── AI (Anthropic — for AI fix loop, later) ────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Sandbox (E2B — wired later, leave blank for now) ───────────────────────
E2B_API_KEY=""

# ─── Workspace preview engine ───────────────────────────────────────────────
# Selects the preview runner. Today only `local` is implemented; `e2b` will
# be wired up later for VM-level isolation suitable for untrusted code.
ORACLE_PREVIEW_PROVIDER="local"
# Override the default workspace + checkpoint roots (defaults to <repo>/oracle-workspaces
# and <repo>/oracle-checkpoints). On a deploy host (Railway etc.), point these
# at a persistent volume so workspaces survive restarts.
WORKSPACES_ROOT=""
CHECKPOINTS_ROOT=""
# Idle reaper: kill previews not hit in this many ms (default 1_200_000 = 20 min)
ORACLE_PREVIEW_IDLE_TIMEOUT_MS=""
# How often the reaper runs (default 60_000 = 60 s)
ORACLE_PREVIEW_SWEEP_INTERVAL_MS=""
# Hard cap on simultaneous previews per host (default 40)
ORACLE_MAX_CONCURRENT_PREVIEWS=""
# Where the disk-backed registry lives (default $TMPDIR/oracle-preview)
ORACLE_PREVIEW_STATE_DIR=""
# Override the public origin used in iframe URLs (default same-origin)
ORACLE_PUBLIC_URL=""

# ─── App ────────────────────────────────────────────────────────────────────
# Public URL of the deployed app (used in emails, share links, OAuth callbacks).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Internal shared secret between API and worker (cron endpoints, signed URLs).
INTERNAL_API_SECRET="generate-with-openssl-rand-base64-32"

# ─── Worker-specific (worker/.env) ──────────────────────────────────────────
# The worker process needs DATABASE_URL, REDIS_URL, RESEND_API_KEY,
# ANTHROPIC_API_KEY, INTERNAL_API_SECRET — copy those over to worker/.env.
